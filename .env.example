# --- Musiclist: gleiche SMTP-Struktur wie Dispo-Kalender (dispo-kalender-dsm) ---
# Bei Gmail ggf. App-Passwort: https://myaccount.google.com/apppasswords
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="dispo@dsm.team"

# Optional: Blindkopie wie im Dispo-Kalender (Standard dispo@dsm.team wenn nicht gesetzt)
# SMTP_BCC=dispo@dsm.team

# Öffentliche App-URL für Einladungs-Mail (Link „Anwendung öffnen“)
MUSICLIST_APP_URL=http://localhost:5273

# Port des API-Servers (Benutzer + Mail; Vite leitet /api dorthin weiter)
MUSICLIST_MAIL_PORT=5274

# Geheimnis für Anmelde-Token (mind. 16 Zeichen). In Produktion zwingend setzen.
# MUSICLIST_AUTH_SECRET=

# Optional: Ordner für app-users.json (Standard: ./data neben dem Projekt)
# MUSICLIST_DATA_DIR=

# Einladungs-Mail (/api/send-user-invite): nur für angemeldete Admins (Bearer-Token), kein separates Geheimnis.
